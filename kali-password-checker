#!/usr/bin/env python3

import argparse
import hashlib
import math
import re
import json
from collections import Counter


def bruteforce_entropy(password):
    size = 0
    if re.search(r"[a-z]", password):
        size += 26
    if re.search(r"[A-Z]", password):
        size += 26
    if re.search(r"[0-9]", password):
        size += 10
    if re.search(r"[^a-zA-Z0-9]", password):
        size += 33
    if size == 0:
        return 0.0
    return len(password) * math.log2(size)


def check_policy(password, policy):
    length, upper, digit, symbol = policy
    if len(password) < length:
        return False
    if upper and not re.search(r"[A-Z]", password):
        return False
    if digit and not re.search(r"[0-9]", password):
        return False
    if symbol and not re.search(r"[^a-zA-Z0-9]", password):
        return False
    return True


def audit_file(filepath, policy=None):
    total = 0
    weak = 0
    compliant = 0
    lengths = []
    entropy_values = []
    pattern_hits = Counter()

    with open(filepath, "r", errors="ignore") as f:
        for line in f:
            pw = line.strip()
            if not pw:
                continue

            total += 1
            lengths.append(len(pw))
            entropy_values.append(bruteforce_entropy(pw))

            if len(pw) < 8:
                weak += 1

            if re.search(r"1234|password|qwerty", pw.lower()):
                pattern_hits["common_pattern"] += 1

            if policy and check_policy(pw, policy):
                compliant += 1

    avg_length = sum(lengths) / total if total else 0
    avg_entropy = sum(entropy_values) / total if total else 0
    weak_percentage = (weak / total * 100) if total else 0
    compliance_percentage = (compliant / total * 100) if total and policy else None

    results = {
        "total_passwords": total,
        "weak_passwords": weak,
        "weak_percentage": round(weak_percentage, 2),
        "average_length": round(avg_length, 2),
        "average_entropy": round(avg_entropy, 2),
        "patterns_detected": dict(pattern_hits),
    }

    if policy:
        results["policy_compliance_percentage"] = round(compliance_percentage, 2)

    return results


def main():
    parser = argparse.ArgumentParser(description="Enterprise Password Audit Toolkit")
    parser.add_argument("--file", help="Audit password file")
    parser.add_argument("--policy", help="Policy format: length,upper,digit,symbol")
    parser.add_argument("--json", help="Export results to JSON file")

    args = parser.parse_args()

    policy = None
    if args.policy:
        parts = args.policy.split(",")
        if len(parts) == 4:
            policy = tuple(int(x) for x in parts)

    if args.file:
        results = audit_file(args.file, policy)

        print("\n=== Audit Results ===")
        for k, v in results.items():
            print(f"{k}: {v}")

        if args.json:
            with open(args.json, "w") as jf:
                json.dump(results, jf, indent=4)

        # exit code for CI/CD
        if results["weak_percentage"] > 30:
            exit(1)
        else:
            exit(0)


if __name__ == "__main__":
    main()
